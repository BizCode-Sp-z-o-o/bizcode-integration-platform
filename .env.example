# ============================================================
# BizCode Integration Platform — Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# ── ACR Credentials (provided by BizCode) ──
ACR_USERNAME=
ACR_PASSWORD=

# ── Platform Settings ──
# Base domain for Nginx Proxy Manager (prod mode)
BASE_DOMAIN=integrations.example.com
# Email for Let's Encrypt certificates
LETSENCRYPT_EMAIL=admin@example.com

# ── Node-RED Admin Credentials ──
NR_ADMIN_USER=admin
NR_ADMIN_PASS=changeme!

# ── Number of BIP instances (0 to 9) ──
BIP_INSTANCE_COUNT=10

# ── Infrastructure Services ──
ENABLE_REDIS=true
ENABLE_RABBITMQ=true
ENABLE_POSTGRES=true
ENABLE_CUPS=true

# ── Redis ──
REDIS_PASSWORD=bizcode-redis-2025

# ── RabbitMQ ──
RABBITMQ_USER=bizcode
RABBITMQ_PASS=bizcode-rmq-2025

# ── PostgreSQL ──
POSTGRES_USER=bizcode
POSTGRES_PASS=bizcode-pg-2025
POSTGRES_DB=bizcode

# ── CUPS Print Server ──
CUPS_ADMIN_USER=admin
CUPS_ADMIN_PASS=bizcode-cups-2025

# ── Nginx Proxy Manager ──
NPM_DB_PASSWORD=bizcode-npm-2025

# ── Extra hosts (for NetBIOS/SAP server resolution) ──
# Format: hostname:ip,hostname2:ip2
# Example: sapserver:192.168.1.100,sapdb:192.168.1.101
EXTRA_HOSTS=
